<Container version="2">
  <Name>Seekify</Name>
  <Repository>ghcr.io/sadoway7/seekify:latest</Repository>
  <Registry>https://github.com/sadoway7/seekify-musicplayer/pkgs/container/seekify</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Icon>https://raw.githubusercontent.com/sadoway7/seekify-musicplayer/main/icon.png</Icon>
  <WebUI>http://[IP]:[PORT:8081]</WebUI>
  <Overview>Self-hosted music server. Scans local libraries, streams audio, fetches MusicBrainz metadata/cover art, and downloads via yt-dlp. Single Go binary + vanilla JS SPA.</Overview>
  <Project>https://github.com/sadoway7/seekify-musicplayer</Project>
  <!-- Create a support thread at forums.unraid.net, then uncomment: -->
  <!-- <Support>https://forums.unraid.net/topic/YOUR_SUPPORT_TOPIC</Support> -->
  <TemplateURL>https://raw.githubusercontent.com/sadoway7/seekify-musicplayer/main/unraid/templates/seekify.xml</TemplateURL>
  <ReadMe>https://github.com/sadoway7/seekify-musicplayer/blob/main/README.md</ReadMe>
  <Category>MediaApp:Music</Category>
  <Changes>Initial Community Apps submission.</Changes>
  <MinVer>6.1</MinVer>
  <License>MIT</License>
  <Screenshot>https://raw.githubusercontent.com/sadoway7/seekify-musicplayer/main/assets/seekify.jpg</Screenshot>
  <Screenshot>https://raw.githubusercontent.com/sadoway7/seekify-musicplayer/main/assets/seekify3.jpg</Screenshot>

  <Config Name="WebUI" Target="8081" Default="8081" Mode="tcp" Description="HTTP port for the WebUI." Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="Appdata" Target="/app/data" Default="/mnt/user/appdata/seekify/data" Mode="rw" Description="SQLite database, cover/waveform cache, download jobs." Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="Music Library" Target="/music" Default="/mnt/user/Media/music" Mode="rw" Description="Primary music directory (read/write — autosort and downloads land here)." Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="Secondary Library" Target="/media-music" Default="" Mode="ro" Description="Optional read-only secondary music library." Type="Path" Display="advanced" Required="false" Mask="false"/>
  <Config Name="MUSIC_DIR" Target="MUSIC_DIR" Default="/music" Mode="" Description="Path inside the container for the primary library." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="MEDIA_MUSIC_DIR" Target="MEDIA_MUSIC_DIR" Default="" Mode="" Description="Set to /media-music only if you mount the Secondary Library path." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="PORT" Target="PORT" Default="8081" Mode="" Description="Container-internal HTTP port. Leave as 8081." Type="Variable" Display="advanced" Required="false" Mask="false"/>
</Container>