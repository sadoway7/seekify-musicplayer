{
  "manifest_version": 3,
  "name": "MusicApp Cookie Sync",
  "version": "1.0.0",
  "description": "Send your YouTube cookies to your self-hosted MusicApp server so music downloads work.",
  "permissions": ["cookies", "storage"],
  "host_permissions": ["*://*.youtube.com/*", "*://*.google.com/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MusicApp Cookie Sync",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
